/*
 * DWM1001 module overlay for the nrf52dk_nrf52832 board target.
 *
 * The DWM1001 module integrates a Nordic nRF52832 and a Decawave DW1000
 * UWB transceiver on a single PCB.  The DW1000 is connected to the nRF52832
 * via SPI1 with the pin mapping below, confirmed from the Decawave DWM1001
 * module schematic and the reference nRF5-SDK firmware (dw1001_dev.h).
 *
 * Pin mapping (nRF52832 port 0):
 *   SPI1 SCK   P0.16
 *   SPI1 MOSI  P0.20
 *   SPI1 MISO  P0.18
 *   SPI1 CS    P0.17  (software-managed CS via cs-gpios, active-low)
 *   DW1000 IRQ    P0.19  (active-high: DW1000 asserts high on event)
 *   DW1000 RST    P0.24  (active-low open-drain: drive low to reset, then release)
 *   DW1000 WAKEUP P0.23  (active-high: drive high >= 500 us to wake from
 *                         DEEPSLEEP, UWB-316 — see drivers/dw1000/dw1000_sleep.h)
 *
 * WAKEUP pin note: this is a placeholder pin assignment for the
 * nrf52dk_nrf52832 stand-in target used throughout this repo (no real DWM1001
 * board file exists yet) — it is NOT verified against a DWM1001 carrier board
 * schematic. Confirm the real WAKEUP trace before relying on this on
 * hardware; see the bring-up checklist in drivers/dw1000/dw1000_sleep.h.
 *
 * SPI driver choice: "nordic,nrf-spi" (non-DMA, interrupt-driven), NOT
 * "nordic,nrf-spim".  The nRF52832 SPIM peripheral has Product Anomaly 58
 * (PAN-58: an extra byte is clocked when RXD.MAXCNT=1 and TXD.MAXCNT<=1).
 * Using the non-DMA SPI driver avoids PAN-58 entirely and matches how the
 * official Decawave DWM1001 dev board configures SPI in the Zephyr tree.
 *
 * The DW1000 SPI device node uses the upstream Zephyr binding at
 * zephyr/dts/bindings/ieee802154/decawave,dw1000.yaml (compatible =
 * "decawave,dw1000", on-bus: spi).  The IRQ property name in that binding is
 * "int-gpios".  The port layer in drivers/dw1000/port/deca_port.c consumes it
 * via SPI_DT_SPEC_GET and GPIO_DT_SPEC_GET.
 *
 * NCS version: v2.7.0 (Zephyr 3.6.x)
 * Uses pinctrl-based pin assignment required by NCS >= v2.1.
 */

#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/adc/nrf-adc.h>

&pinctrl {
	spi1_default: spi1_default {
		group1 {
			psels = <NRF_PSEL(SPIM_SCK,  0, 16)>,
				<NRF_PSEL(SPIM_MOSI, 0, 20)>,
				<NRF_PSEL(SPIM_MISO, 0, 18)>;
		};
	};

	spi1_sleep: spi1_sleep {
		group1 {
			psels = <NRF_PSEL(SPIM_SCK,  0, 16)>,
				<NRF_PSEL(SPIM_MOSI, 0, 20)>,
				<NRF_PSEL(SPIM_MISO, 0, 18)>;
			low-power-enable;
		};
	};
};

&spi1 {
	compatible = "nordic,nrf-spi";
	status = "okay";
	pinctrl-0 = <&spi1_default>;
	pinctrl-1 = <&spi1_sleep>;
	pinctrl-names = "default", "sleep";
	cs-gpios = <&gpio0 17 GPIO_ACTIVE_LOW>;

	/*
	 * DW1000 UWB transceiver — SPI slave 0 (CS = gpio0.17).
	 *
	 * spi-max-frequency is the fast operating frequency (8 MHz).
	 * The port layer (port_set_dw1000_slowrate) overrides this to 2 MHz
	 * before calling dwt_initialise(), then restores it via
	 * port_set_dw1000_fastrate() after initialisation.
	 */
	dw1000: dw1000@0 {
		compatible = "decawave,dw1000";
		reg = <0>;
		spi-max-frequency = <8000000>;    /* 8 MHz fast rate */
		int-gpios   = <&gpio0 19 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&gpio0 24 GPIO_ACTIVE_LOW>;
	};
};

/*
 * DW1000 WAKEUP GPIO (UWB-316).
 *
 * The upstream "decawave,dw1000" binding does not define a wakeup-gpios
 * property (this repo does not own/vendor that binding, so it is not
 * extended directly) — wired instead on the generic, schema-free
 * `/{ zephyr,user { ... }; };` node, Zephyr's standard mechanism for ad hoc
 * board GPIO wiring outside a device's own binding. See
 * drivers/dw1000/port/deca_port.c (port_wakeup_dw1000(), guarded on
 * DT_NODE_HAS_PROP so boards without this property build unaffected) and
 * drivers/dw1000/dw1000_sleep.c (dw1000_wake()).
 */
/ {
	zephyr,user {
		wakeup-gpios = <&gpio0 23 GPIO_ACTIVE_HIGH>;

		/*
		 * Battery voltage monitor ADC channel (UWB-322, ADR-0046
		 * point 5). Index 0 into this node's io-channels list is
		 * what src/battery_zephyr.c's ADC_DT_SPEC_GET(DT_PATH(zephyr_user))
		 * resolves to (idx defaults to 0) -- see &adc's channel@0
		 * below for the actual gain/reference/resolution config,
		 * which src/battery.h's conversion constants must match.
		 */
		io-channels = <&adc 0>;
	};
};

/*
 * SAADC channel reading NRF_SAADC_VDD (UWB-322, ADR-0046 point 5).
 *
 * Gain 1/6 + internal 0.6 V reference gives a 3.6 V full-scale range
 * (0.6 V / (1/6) = 3.6 V), comfortably spanning the tag's expected
 * single-cell Li-based VDD range (~1.8-3.6 V) without an external divider --
 * the standard nRF52 "read VDD via SAADC" configuration (see
 * src/battery.h's header comment for the full derivation
 * battery_raw_to_millivolts() relies on).
 *
 * &adc defaults to status = "disabled" in the SoC devicetree
 * (zephyr/dts/arm/nordic/nrf52832.dtsi) -- must be explicitly re-enabled
 * here.
 */
&adc {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	channel@0 {
		reg = <0>;
		zephyr,gain = "ADC_GAIN_1_6";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 40)>;
		zephyr,input-positive = <NRF_SAADC_VDD>;
		zephyr,resolution = <12>;
	};
};
